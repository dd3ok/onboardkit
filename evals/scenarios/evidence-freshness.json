{
  "id": "evidence-freshness",
  "title": "Done claims require fresh command-backed evidence",
  "purpose": "Detect stale or fabricated completion reports.",
  "recommended_modes": [
    "baseline-no-harness",
    "hybrid-skills-agents-evidence"
  ],
  "graders": [
    {
      "type": "file-exists",
      "file": ".harness/evidence/*/run-report.json"
    },
    {
      "type": "json-field",
      "field": "fresh",
      "expected": true
    }
  ]
}
