{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/agent-onboard/evidence.schema.json",
  "title": "Agent Onboard Evidence Proof",
  "type": "object",
  "required": [
    "run_id",
    "criterion_id",
    "type",
    "description",
    "required",
    "created_at"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "criterion_id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "command": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "observed_at": {
      "type": "string"
    },
    "normalized_command": {
      "type": "string"
    },
    "cwd": {
      "type": "string"
    },
    "required": {
      "type": "boolean"
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "exit_code": {
      "type": [
        "integer",
        "null"
      ]
    },
    "stdout_sha256": {
      "type": "string"
    },
    "stderr_sha256": {
      "type": "string"
    },
    "fresh": {
      "type": "boolean"
    },
    "ok": {
      "type": "boolean"
    },
    "policy_status": {
      "enum": [
        "allowed",
        "denied",
        "prompt-required"
      ]
    },
    "policy_rule": {
      "type": "string"
    },
    "policy_reason": {
      "type": "string"
    },
    "policy_source": {
      "type": "string"
    },
    "policy_approval": {
      "type": "boolean"
    },
    "policy_approval_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "timeout_ms": {
      "type": "integer"
    },
    "max_output_bytes": {
      "type": "integer"
    },
    "timed_out": {
      "type": "boolean"
    },
    "output_limited": {
      "type": "boolean"
    },
    "error_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "artifact_kind": {
      "type": "string"
    },
    "artifact_relative_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "artifact_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "artifact_size_bytes": {
      "type": "integer"
    },
    "artifact_mtime": {
      "type": "string"
    },
    "artifact_sha256": {
      "type": "string"
    },
    "note": {
      "type": "string"
    }
  }
}
