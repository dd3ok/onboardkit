{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/agent-onboard/evidence.schema.json",
  "title": "Agent Onboard Evidence Proof",
  "type": "object",
  "required": [
    "run_id",
    "criterion_id",
    "type",
    "description",
    "required",
    "created_at"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "criterion_id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "command": {
      "type": "string"
    },
    "cwd": {
      "type": "string"
    },
    "required": {
      "type": "boolean"
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "exit_code": {
      "type": [
        "integer",
        "null"
      ]
    },
    "stdout_sha256": {
      "type": "string"
    },
    "stderr_sha256": {
      "type": "string"
    },
    "fresh": {
      "type": "boolean"
    },
    "ok": {
      "type": "boolean"
    }
  }
}
