{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/after-init/security-policy.schema.json",
  "title": "after-init Security Policy",
  "type": "object",
  "required": [
    "version"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "unknown": {
      "enum": [
        "deny",
        "allow"
      ],
      "default": "deny"
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 1,
      "default": 120000
    },
    "max_output_bytes": {
      "type": "integer",
      "minimum": 1,
      "default": 1048576
    },
    "allow": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "deny": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      },
      "default": []
    },
    "prompt": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      },
      "default": []
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "required": [
        "id",
        "reason"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "exact": {
          "type": "string"
        },
        "contains": {
          "type": "string"
        },
        "regex": {
          "type": "string"
        },
        "flags": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      },
      "anyOf": [
        {
          "required": [
            "exact"
          ]
        },
        {
          "required": [
            "contains"
          ]
        },
        {
          "required": [
            "regex"
          ]
        }
      ]
    }
  }
}
