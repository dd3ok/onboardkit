{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/after-init/task.schema.json",
  "title": "after-init Task",
  "type": "object",
  "required": [
    "id",
    "description",
    "verification"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "parallelizable": {
      "type": "boolean"
    },
    "verification": {
      "type": "string"
    },
    "evidence_path": {
      "type": "string"
    }
  }
}
