{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/agent-onboard/criteria.schema.json",
  "title": "Agent Onboard Criteria",
  "type": "object",
  "required": [
    "criteria"
  ],
  "properties": {
    "criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "enum": [
              "command",
              "artifact",
              "screenshot",
              "browser-log",
              "review",
              "manual"
            ]
          },
          "command": {
            "type": "string"
          },
          "path": {
            "type": "string",
            "description": "Project-relative path for artifact-backed evidence."
          },
          "note": {
            "type": "string"
          },
          "timeout_ms": {
            "type": "integer",
            "minimum": 1
          },
          "max_output_bytes": {
            "type": "integer",
            "minimum": 1
          },
          "policy_approval": {
            "type": "boolean",
            "default": false
          },
          "policy_approval_reason": {
            "type": "string"
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      }
    }
  }
}
