{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/prooflane/criteria.schema.json",
  "title": "Agent Harness Criteria",
  "type": "object",
  "required": [
    "criteria"
  ],
  "properties": {
    "criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "enum": [
              "command",
              "artifact",
              "screenshot",
              "browser-log",
              "review",
              "manual"
            ]
          },
          "command": {
            "type": "string"
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      }
    }
  }
}
